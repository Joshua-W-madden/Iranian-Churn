import pandas as pd 
import numpy as np
from sklearn.model_selection import train_test_split
from sklearn.linear_model import LogisticRegression
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import confusion_matrix
from sklearn.metrics import roc_curve, auc
import matplotlib.pyplot as plt

X = pd.read_csv("cleanedNonC.csv")
y = pd.read_csv("cleanedChurn.csv")
y = y["Churn"].values.ravel()

# Randomly selects 20% of data and denotes for testing and remainder is used for our training
X_train, X_test, y_train, y_true = train_test_split(
    X, y,
    test_size=0.2,
    random_state=1 #used random state so this is repeatable as we will reuse the "randomizer" pattern through every rerun or refactor
)

model = LogisticRegression(max_iter=2000)
model.fit(X_train, y_train)
x_pred = model.predict(X_test)
tPred = np.sum(x_pred == 1)
fPred = np.sum(x_pred == 1)

#metrics
tValues = np.sum(X_test == 1)
fValues = np.sum(X_test == 0)
cf = confusion_matrix(y_true, x_pred)
TN, FP, FN, TP = cf.ravel()
precision = TP / (TP + FP)
recall    = TP / (TP + FN)
f1_score  = 2 * (precision * recall) / (precision + recall)

print("\n----Logistic Regression----")
print("\nConfusion Matrix:\n", confusion_matrix(y_true, x_pred))
print("recall: ", recall)
print("precision: ", precision)
print("f1 score: ", f1_score)

coef = model.coef_[0]
feature_names = X.columns

print("\nColumn Coefficient:")
for name, score in zip(feature_names, coef):
    print(f"{name}: {score}")

model2 = RandomForestClassifier(
    n_estimators=100,
    max_depth=10,
    random_state=1
)
model2.fit(X_train, y_train)

# Predict
predictions = model2.predict(X_test)
tPred = np.sum(predictions == 1)
fPred = np.sum(predictions == 0)

#metrics
tValues = np.sum(y_true == 1)
fValues = np.sum(y_true == 0)
cf = confusion_matrix(y_true, predictions)
TN, FP, FN, TP = cf.ravel()
precision = TP / (TP + FP)
recall    = TP / (TP + FN)
f1_score  = 2 * (precision * recall) / (precision + recall)

print("\n\n----Random Forest----")
print("Confusion Matrix:\n", confusion_matrix(y_true, predictions))
print("recall: ", recall)
print("precision: ", precision)
print("f1 score: ", f1_score)

importances = model2.feature_importances_

print("\nImportance: ")
for name, score in zip(feature_names, importances):
    print(f"{name}: {score}")
          
lr_probs = model.predict_proba(X_test)[:, 1]
rf_probs = model2.predict_proba(X_test)[:, 1]


# Compute ROC curves
fpr_lr, tpr_lr, _ = roc_curve(y_true, lr_probs)
fpr_rf, tpr_rf, _ = roc_curve(y_true, rf_probs)

# area under curve
auc_lr = auc(fpr_lr, tpr_lr)
auc_rf = auc(fpr_rf, tpr_rf)

plt.figure()

plt.plot(fpr_lr, tpr_lr, label=f"Logistic Regression (AUC = {auc_lr:.2f})")
plt.plot(fpr_rf, tpr_rf, label=f"Random Forest (AUC = {auc_rf:.2f})")

# Random baseline
plt.plot([0, 1], [0, 1], linestyle="--", label="Random Classifier")

plt.xlabel("False Positive Rate")
plt.ylabel("True Positive Rate")
plt.title("ROC Curve Comparison")
plt.legend()

plt.show()