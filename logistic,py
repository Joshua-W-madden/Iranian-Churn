import pandas as pd 
from sklearn.model_selection import train_test_split
from sklearn.linear_model import LogisticRegression
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import accuracy_score, classification_report, confusion_matrix
from sklearn.metrics import roc_curve, auc
import matplotlib.pyplot as plt

X = pd.read_csv("cleanedNonC.csv")
y = pd.read_csv("cleanedChurn.csv")
y = y["Churn"].values.ravel()

# Randomly selects 20% of data and denotes for testing and remainder is used for our training
X_train, X_test, y_train, y_test = train_test_split(
    X, y,
    test_size=0.2,
    random_state=1 #used random state so this is repeatable as we will reuse the "randomizer" pattern through every rerun or refactor
)

model = LogisticRegression(max_iter=2000)
model.fit(X_train, y_train)
y_pred = model.predict(X_test)

print("\nLogistic Regression")
print("Accuracy:", accuracy_score(y_test, y_pred))
print("\nConfusion Matrix:\n", confusion_matrix(y_test, y_pred))
print("\nReport:\n", classification_report(y_test, y_pred))
coefficients = model.coef_[0]
feature_names = X.columns

print("Weight of each catagory")
for feature, coef in zip(feature_names, coefficients):
    print(f"{feature}: {coef}")


model2 = RandomForestClassifier(
    n_estimators=100,
    max_depth=10,
    random_state=42
)
model2.fit(X_train, y_train)

# Predict
predictions = model2.predict(X_test)

print("\n\nRandom Forest")
print("Accuracy:", accuracy_score(y_test, predictions))
print("\nConfusion Matrix:\n", confusion_matrix(y_test, predictions))
print("\nReport:\n", classification_report(y_test, predictions))

importance = model2.feature_importances_
feature_names = X.columns

feat_imp = pd.Series(importance, index=feature_names)
print("Importance of each catagory")
print(feat_imp.sort_values(ascending=False))

lr_probs = model.predict_proba(X_test)[:, 1]
rf_probs = model2.predict_proba(X_test)[:, 1]


# Compute ROC curves
fpr_lr, tpr_lr, _ = roc_curve(y_test, lr_probs)
fpr_rf, tpr_rf, _ = roc_curve(y_test, rf_probs)

# area under curve
auc_lr = auc(fpr_lr, tpr_lr)
auc_rf = auc(fpr_rf, tpr_rf)

plt.figure()

plt.plot(fpr_lr, tpr_lr, label=f"Logistic Regression (AUC = {auc_lr:.2f})")
plt.plot(fpr_rf, tpr_rf, label=f"Random Forest (AUC = {auc_rf:.2f})")

# Random baseline
plt.plot([0, 1], [0, 1], linestyle="--", label="Random")

plt.xlabel("False Positive Rate")
plt.ylabel("True Positive Rate")
plt.title("ROC Curve Comparison")
plt.legend()

plt.show()